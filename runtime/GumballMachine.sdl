statemachine GumballMachine {
    var int balls;

    initial NoQuarter;
    state NoQuarter
        entry insertMessage impl "System.out.println(\"Plesase insert coin...\");";
    state HasQuarter;
    state Sold;
    state SoldOut
        entry soldOutMessage impl "System.out.println(\"Machine is sold out\");"
        exit refillMessage desc "Print a message indicating that the machine is getting refilled now.";
    state Final
        entry shutdownMessage impl "System.out.println(\"System is shutting down ....\");\n context.setState(null);";
 
    NoQuarter -> HasQuarter / insertQuarter
        desc "Print a message indicating that the machine is ready and the money was accepted";

    HasQuarter -> NoQuarter on eject / eject
        impl "System.out.println(\"Returning coin...\");";

    HasQuarter -> Sold / turnCrank
        impl "System.out.println(\"Turning crank...\");";

    SoldOut -> NoQuarter on refill(int amount) / refill
        desc "add the amount of the balls variable and print a message that the Machine has been refilled to $n Gumballs";

    Sold -> NoQuarter on dispense / dispense
        impl "context.decrementBalls();\n System.out.println(\"dispensing ball\");"
        [balls > 1];

    Sold -> SoldOut on dispense / dispense
        impl "context.decrementBalls();\n System.out.println(\"machine is empty!\");"
        [balls == 1]; 

    NoQuarter -> Final on abandon;
    HasQuarter -> Final on abandon;
    Sold -> Final on abandon;
    SoldOut -> Final on abandon;
}
