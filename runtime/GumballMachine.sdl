statemachine GumballMachine {
    var int balls

    initial NoQuarter
    state NoQuarter
        entry / impl java << System.out.println("Plesase insert coin..."); >>
    state HasQuarter
    state Sold
    state SoldOut
        entry / impl java << System.out.println("Machine is sold out"); >>
        exit / spec "Print a message indicating that the machine is getting refilled now."
    final state TheEnd
        entry / impl java << System.out.println("System is shutting down ....");
        context.setState(null); >>
 
    NoQuarter -> HasQuarter on insertQuarter /
        spec "Print a message indicating that the machine is ready and the money was accepted"

    HasQuarter -> NoQuarter on eject / 
        impl java << System.out.println("Returning coin..."); >>

    HasQuarter -> Sold on turnCrank /
        impl java << System.out.println("Turning crank...");>>

    SoldOut -> NoQuarter on refill(int amount) / 
        spec "add the amount of the balls variable and print a message that the Machine has been refilled to $n Gumballs"

    Sold -> NoQuarter on dispense / 
        impl java << context.decrementBalls();
        System.out.println("dispensing ball");>>
        [balls > 1]

    Sold -> SoldOut on dispense / 
        impl java << context.decrementBalls(); 
        System.out.println("machine is empty!");>>
        [balls == 1]

    NoQuarter -> TheEnd on abandon
    HasQuarter -> TheEnd on abandon
    Sold -> TheEnd on abandon
    SoldOut -> TheEnd on abandon
}
