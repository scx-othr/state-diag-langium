{
    "name": "statelang-cli",
    "displayName": "Statelang CLI",
    "description": "CLI and VS Code integration for Statelang.",
    "version": "0.0.1",
    "publisher": "your-name-or-org",
    "type": "module",
    "main": "./out/extension.js",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:statelang",
        "onCommand:statelang.generate"
    ],
    "contributes": {
        "commands": [
            {
                "command": "statelang.generate",
                "title": "Generate Java Code",
                "category": "Statelang"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "command": "statelang.generate",
                    "title": "Generate Java Code",
                    "when": "resourceExtname == .sdl"
                }
            ],
            "editor/context": [
                {
                    "command": "statelang.generate",
                    "title": "Generate Java Code",
                    "when": "resourceExtName == .sdl"
                }
            ]
        }
    },
    "bin": {
        "statelang-cli": "./bin/cli.js"
    },
    "scripts": {
        "clean": "shx rm -fr *.tsbuildinfo out",
        "build": "tsc -b",
        "build:clean": "npm run clean && npm run build",
        "generate": "node ./out/main.js generate"
    },
    "dependencies": {
        "chalk": "~5.3.0",
        "commander": "~11.1.0",
        "langium": "^4.1.3",
        "statelang-language": "0.0.1"
    },
    "devDependencies": {
        "typescript": "^5.3.0",
        "vsce": "^2.15.0"
    },
    "volta": {
        "node": "20.19.2",
        "npm": "10.8.2"
    }
}
