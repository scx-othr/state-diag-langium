{
    "name": "vscode-state-diagram",
    "description": "The extension specific package",
    "version": "0.0.1",
    "displayName": "state-diagram",
    "type": "module",
    "publisher": "empeling",
    "engines": {
    "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [{
            "id": "statelang",
            "aliases": ["statelang", "statelang"],
            "extensions": [".sdl"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "statelang",
            "scopeName": "source.statelang",
            "path": "syntaxes/statelang.tmLanguage.json",
            "embeddedLanguages": {
                "source.java": "java"
            }
        }],
        "commands": [
            {
                "command": "statelang.showPlantUML",
                "title": "Show PlantUML Preview",
                "icon": "$(preview)",
                "category": "StateLang"
            },
            {
                "command": "statelang.generateJava",
                "title": "Generate Java Code",
                "category": "StateLang"
            }
        ],
        "menus": {
            "editor/title": [{
                "command": "statelang.showPlantUML",
                "when": "resourceLangId == statelang",
                "group": "navigation"
            }],
            "explorer/context": [{
                "command": "statelang.generateJava",
                "when": "resourceExtname == .sdl",
                "group": "statelang@1"
            }]
        },
        "configurationDefaults": {
            "editor.tokenColorCustomizations": {
                "textMateRules": [
                    {
                        "scope": "entity.name.type.state.initial.statelang",
                        "settings": {
                            "foreground": "#4EC9B0",
                            "fontStyle": "bold"
                        }
                    },
                    {
                        "scope": "entity.name.type.state.final.statelang",
                        "settings": {
                            "foreground": "#4CAF82",
                            "fontStyle": "bold"
                        }
                    },
                    {
                        "scope": "entity.name.type.state.statelang",
                        "settings": {
                            "foreground": "#9CDCFE"
                        }
                    },
                    {
                        "scope": "entity.name.type.state.reference.statelang",
                        "settings": {
                            "foreground": "#DCDCAA"
                        }
                    }
                ]
            }
        }
    },
    "activationEvents": [
        "onLanguage:statelang",
        "onCommand:statelang.generateJava"
    ],
    "main": "./out/extension/main.cjs",
    "scripts": {
        "clean": "shx rm -fr *.tsbuildinfo out syntaxes",
        "vscode:prepublish": "npm run build",
        "build:prepare": "shx mkdir -p ./syntaxes/ && shx cp -f ../language/syntaxes/statelang.tmLanguage.json ./syntaxes/statelang.tmLanguage.json",
        "build": "npm run build:prepare && tsc -b tsconfig.json && node esbuild.mjs",
        "build:clean": "npm run clean && npm run build",
        "watch": "npm run build:prepare && concurrently -n tsc,esbuild -c blue,yellow \"tsc -b tsconfig.json --watch\" \"node esbuild.mjs --watch\""
    },
    "dependencies": {
        "statelang-language": "0.0.1",
        "vscode-languageclient": "~9.0.1",
        "vscode-languageserver": "~9.0.1"
    },
    "devDependencies": {
        "@types/vscode": "~1.67.0",
        "concurrently": "~8.2.1",
        "esbuild": "~0.25.5"
    },
    "vsce": {
      "dependencies": false
    }
}
